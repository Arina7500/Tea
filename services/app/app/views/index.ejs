<!DOCTYPE html>
<html lang="ru">

    <head>
        <meta charset="UTF-8">
        <title>Чайный магазин</title>
        <link rel="stylesheet" href="/css/index.css">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/cn-fontsource-yozai/font.css">
        <script src="/js/cart.js"></script>
    </head>
    <body>

        <!--Слой 1-->
        <div class="bg-top"></div>
    
        <!--Слой 2-->
        <div class="bg-bottom"></div>

        <div class="bg-mid"></div>

        <nav>
            <a href="/">Главная</a>
            <a href="/about">О нас</a> 
            <a href="/catalog">Каталог</a> 
            <a href="/journal">Журнал о чае</a> 
            <a href="/cart">Корзина (<span id="cart-counter">0</span>)</a>
        </nav>

        <h1>Хэ Цзин И</h1>
        <h5>Гармония Уважение Истина</h5>

        <div>
            <img src="/images/китаец.png" class="chinese" alt="Китаец">
        </div>

        <div class="slider-container">
            <div class="swiper">
                <div class="swiper-wrapper">
                    <!--Слайд 1-->
                    <div class="swiper-slide">
                        <div class="slide-image">
                            <img src="/images/китайский_чай.jpg" alt="Китайский чай">
                        </div>
                        <div class="slide-content">
                            <h3>Китайский чай</h3>
                            <p>Собирается по старинным рецептам в тот короткий сезон, когда чайный лист достигает совершенства.
                                Тысячелетние традиции чаеделия в каждой горсти чая.</p>
                        </div>
                    </div>
                    
                    <!--Слайд 2-->
                    <div class="swiper-slide">
                        <div class="slide-image">
                            <img src="/images/виды_чаёв.jpg" alt="Виды чаёв">
                        </div>
                        <div class="slide-content">
                            <h3>Виды чаёв</h3>
                            <p>Чай с гор Фуцзяни, из туманных долин Юньнани и 
                                с высокогорных плантаций Тайваня — мы привезли для вас лучшие листья со всего Китая.
                                Каждая провинция Китая хранит свои чайные секреты. Позвольте нам познакомить вас с ними.
                            </p>
                        </div>
                    </div>
                    
                    <!--Слайд 3-->
                    <div class="swiper-slide">
                        <div class="slide-image">
                            <img src="/images/чайная_церемония.jpg" alt="Чайная церемония">
                        </div>
                        <div class="slide-content">
                            <h3>Чайная церемония</h3>
                            <p>Погрузитесь в атмосферу настоящей китайской чайной церемонии.
                                Гармония начинается с маленького ритуала. Создайте его для себя.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="swiper-button-prev nav-button"></div>
                <div class="swiper-button-next nav-button"></div>
                
                <div class="swiper-pagination"></div>
            </div>
        </div>

        <!-- Динамические карточки категорий из БД -->
        <div class="cards-container">
            <h2>Чайная карта</h2>
            <div class="category-grid">
                <% if (categories && categories.length > 0) { %>
                    <% categories.forEach(category => { %>
                        <div class="card">
                            <img src="<%= category.image_url %>" class="card-image" alt="<%= category.name %>">
                            <div class="card-content">
                                <h3><%= category.name %></h3>
                                <p><%= category.description %></p>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p>Категории не найдены</p>
                <% } %>
            </div>
        </div>

        <!-- Динамические популярные товары из БД -->
        <section class="popular-products">
            <h2>Популярные товары</h2>

            <div class="swiper popular-swiper">
                <div class="swiper-wrapper">

                    <% if (popularProducts && popularProducts.length > 0) { %>
                        <!-- Группируем товары по 3 в слайд -->
                        <% for (let i = 0; i < popularProducts.length; i += 3) { %>
                            <div class="swiper-slide">
                                <div class="product-grid">
                                    <% for (let j = i; j < i + 3 && j < popularProducts.length; j++) { 
                                        const product = popularProducts[j];
                                    %>
                                        <div class="product-card">
                                            <% if (product.badge) { %>
                                                <div class="product-badge"><%= product.badge %></div>
                                            <% } %>
                                            <img src="<%= product.image_url %>" alt="<%= product.name %>" class="product-image">
                                            <h3><%= product.name %></h3>
                                            <p><%= product.description %></p>
                                            <p class="product-price"><%= product.price %> ₽</p>
                                            <button class="product-btn" onclick="addToCart(<%= product.id %>)">Купить</button>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        <% } %>
                    <% } else { %>
                        <div class="swiper-slide">
                            <p>Товары не найдены</p>
                        </div>
                    <% } %>

                </div>

                <div class="swiper-button-prev popular-prev"></div>
                <div class="swiper-button-next popular-next"></div>

                <div class="swiper-pagination popular-pagination"></div>
            </div>
        </section>

        <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
        <script src="/js/index.js"></script>

        <section class="information">
            <h2>Интернет-магазин китайского чая Хэ Цзин И</h2>
            <h3>Китайский чай с доставкой по всему миру</h3>
            <img src="/images/символ_чая.png" class="tea-image" alt="Символ чая">
            <p>На сегодняшний день мы являемся надежными поставщиками качественного 
                китайского чая, как на территории России, так и за рубеж. 
                Хорошо отлаженная логистика позволяет в кратчайшие сроки доставлять 
                заказы даже в самые отдаленные места. 
                Сотрудничество с курьерскими службами транспортных компаний обеспечивает максимально 
                бережную и качественную доставку хрупкой чайной утвари и чая в руки покупателя.
            </p>

            <h3>Сеть уютных чайных</h3>
            <img src="/images/символ_чайной.png" class="tea-image" alt="Символ чайной">
            <p>
                В наших уютных чайных магазинах посетители могут не только купить китайский 
                чай, но и продегустировать его перед покупкой. Чайные мастера индивидуально 
                консультируют каждого в выборе чая и посуды, благодаря чему мы получаем 
                огромное количество благодарных клиентов, приходящих к нам снова вместе 
                с друзьями.
            </p>

            <h3>Команда профессионалов</h3>
            <img src="/images/символ_китая.png" class="tea-image" alt="Символ Китая">
            <p>
                Наша компания состоит из активных молодых людей заинтересованных в развитии. 
                Среди нас есть настоящие ценители китайского чая, постоянно находящиеся в 
                поиске чего-то нового и интересного. Есть яркие, творческие личности. 
                Есть предприниматели, благодаря которым движемся вперед. 
                Есть дизайнеры, придающие особый стиль. Наши менеджеры профессионалы высокого
                уровня, к которым вы всегда можете обратиться и получить всю необходимую 
                информацию.
            </p>
        </section>

        <footer class="footer">
            <div class="footer-container">
                <div class="footer-top">
                    <div class="footer-col footer-about">
                        <h3 class="footer-logo">Хэ Цзин И</h3>
                        <p class="footer-tagline">Гармония · Уважение · Истина</p>
                        <p class="footer-description">
                            Магазин настоящего китайского чая. 
                            Прямые поставки из чайных провинций Китая.
                        </p>
                    </div>
                    
                    <div class="footer-col footer-menu">
                        <h4 class="footer-title">Навигация</h4>
                        <ul class="footer-links">
                            <li><a href="/">Главная</a></li>
                            <li><a href="/catalog">Каталог</a></li>
                            <li><a href="/about">О нас</a></li>
                            <li><a href="#">Журнал о чае</a></li>
                            <li><a href="#">Контакты</a></li>
                        </ul>
                    </div>
                    
                    <div class="footer-col footer-contact">
                        <h4 class="footer-title">Контакты</h4>
                        <ul class="footer-contact-list">
                            <li>
                                <span>г. Москва, ул. Чайная, д. 42</span>
                            </li>
                            <li>
                                <span>+7 (999) 123-45-67</span>
                            </li>
                            <li>
                                <span>info@hejingyi.ru</span>
                            </li>
                            <li>
                                <span>Пн-Пт: 10:00 - 20:00</span>
                            </li>
                        </ul>
                    </div>
                </div>
                
                <div class="footer-bottom">
                    <p>© 2025 Хэ Цзин И. Все права защищены.</p>
                    <p class="footer-credits">
                        <a href="#">Политика конфиденциальности</a> | 
                        <a href="#">Условия использования</a>
                    </p>
                </div>
            </div>
        </footer>

        <div id="sakura-container" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 9999;"></div>

    </body>
</html>