<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Каталог - Чайный магазин</title>
    <link rel="stylesheet" href="/css/catalog.css">
    <script src="/js/cart.js"></script>
</head>
<body>
    <nav>
        <a href="/">Главная</a>
        <a href="/about">О нас</a>
        <a href="/catalog">Каталог</a>
        <a href="/journal">Журнал о чае</a>
        <a href="/cart">Корзина (<span id="cart-counter"><%= cartCount %></span>)</a>
    </nav>

    <aside class="sidebar">
        <img src="/images/icon.png" class="icon-image">
        <nav class="sidebar-nav">
            <a href="#tea" class="sidebar-link">Чай</a>
            <a href="#tea-mixes" class="sidebar-link">Чайные смеси</a>
            <a href="#utensils" class="sidebar-link">Чайная утварь</a>
            <a href="#popular" class="sidebar-link">Популярное</a>
        </nav>
    </aside>

    <main class="main-content">
        <!-- Секция Чай -->
        <section id="tea" class="content-section">
            <h2>Чай</h2>
            <div class="product-grid">
                <% if (teas && teas.length > 0) { %>
                    <% teas.forEach(product => { %>
                        <div class="product-card">
                            <img src="<%= product.image_url %>" alt="<%= product.name %>" class="product-image">
                            <h3><%= product.name %></h3>
                            <p><%= product.description %></p>
                            <p class="product-price"><%= product.price %> ₽/100 г</p>
                            <button class="product-btn" onclick="addToCart(<%= product.id %>)">Купить</button>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p>Товары не найдены</p>
                <% } %>
            </div>
        </section>

        <!-- Секция Чайные смеси -->
        <section id="tea-mixes" class="content-section">
            <h2>Чайные смеси</h2>
            <div class="product-grid">
                <% if (teaMixes && teaMixes.length > 0) { %>
                    <% teaMixes.forEach(product => { %>
                        <div class="product-card">
                            <img src="<%= product.image_url %>" alt="<%= product.name %>" class="product-image">
                            <h3><%= product.name %></h3>
                            <p><%= product.description %></p>
                            <p class="product-price"><%= product.price %> ₽</p>
                            <button class="product-btn" onclick="addToCart(<%= product.id %>)">Купить</button>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p>Товары не найдены</p>
                <% } %>
            </div>
        </section>

        <!-- Секция Чайная утварь -->
        <section id="utensils" class="content-section">
            <h2>Чайная утварь</h2>
            <div class="product-grid">
                <% if (utensils && utensils.length > 0) { %>
                    <% utensils.forEach(product => { %>
                        <div class="product-card">
                            <img src="<%= product.image_url %>" alt="<%= product.name %>" class="product-image">
                            <h3><%= product.name %></h3>
                            <p><%= product.description %></p>
                            <p class="product-price"><%= product.price %> ₽</p>
                            <button class="product-btn" onclick="addToCart(<%= product.id %>)">Купить</button>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p>Товары не найдены</p>
                <% } %>
            </div>
        </section>

        <!-- Секция Популярное -->
        <section id="popular" class="content-section">
            <h2>Популярное</h2>
            <div class="product-grid">
                <% if (popular && popular.length > 0) { %>
                    <% popular.forEach(product => { %>
                        <div class="product-card">
                            <img src="<%= product.image_url %>" alt="<%= product.name %>" class="product-image">
                            <h3><%= product.name %></h3>
                            <p><%= product.description %></p>
                            <p class="product-price"><%= product.price %> ₽</p>
                            <button class="product-btn" onclick="addToCart(<%= product.id %>)">Купить</button>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p>Товары не найдены</p>
                <% } %>
            </div>
        </section>
    </main>

    <footer class="footer">
        <div class="footer-container">
            <div class="footer-top">
                <div class="footer-col footer-about">
                    <h3 class="footer-logo">Хэ Цзин И</h3>
                    <p class="footer-tagline">Гармония · Уважение · Истина</p>
                </div>
                <div class="footer-col footer-menu">
                    <h4 class="footer-title">Навигация</h4>
                    <ul class="footer-links">
                        <li><a href="/">Главная</a></li>
                        <li><a href="/catalog">Каталог</a></li>
                        <li><a href="/about">О нас</a></li>
                    </ul>
                </div>
                <div class="footer-col footer-contact">
                    <h4 class="footer-title">Контакты</h4>
                    <ul class="footer-contact-list">
                        <li>г. Москва, ул. Чайная, д. 42</li>
                        <li>+7 (999) 123-45-67</li>
                        <li>info@hejingyi.ru</li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>© 2025 Хэ Цзин И. Все права защищены.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script src="/js/index.js"></script>
</body>
</html>